TT 18778 "We've got intruders here!" VO__SOLDIER_S1__GENERIC__PATROL__ALERT__001__M__2
TT 18779 "Trespassers! Everyone with me!" VO__SOLDIER_S1__GENERIC__PATROL__ALERT__001__M__3
TT 18780 "You! Come here!" VO__SOLDIER_S1__GENERIC__PATROL__ALERT_ALONE__001__M__1
