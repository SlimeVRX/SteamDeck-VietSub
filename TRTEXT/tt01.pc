TT 13781 "Three!" VO__LUCAS__CH01__CHATTER__HIDESEEK_COUNTING__030__M__1
TT 13782 "Four!" VO__LUCAS__CH01__CHATTER__HIDESEEK_COUNTING__040__M__1
TT 13783 "Fiiive!" VO__LUCAS__CH01__CHATTER__HIDESEEK_COUNTING__050__M__1
TT 13784 "Six!" VO__LUCAS__CH01__CHATTER__HIDESEEK_COUNTING__060__M__1
TT 13785 "Seven!" VO__LUCAS__CH01__CHATTER__HIDESEEK_COUNTING__070__M__1
TT 13786 "Eight!" VO__LUCAS__CH01__CHATTER__HIDESEEK_COUNTING__080__M__1
TT 13787 "Niiine!" VO__LUCAS__CH01__CHATTER__HIDESEEK_COUNTING__090__M__1
