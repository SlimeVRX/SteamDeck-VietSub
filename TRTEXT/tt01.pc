TT 6084 "Pull him away!" VO__AMICIA__CH10__CHATTER__AFTER_EVENT_KNIFE__010__M__1
TT 6085 "Ha... Thank you..." VO__AMICIA__CH10__CHATTER__AFTER_EVENT_KNIFE__023__M__1
TT 6086 "Hugo... It's over..." VO__AMICIA__CH10__CHATTER__AFTER_EVENT_KNIFE__030__M__1
