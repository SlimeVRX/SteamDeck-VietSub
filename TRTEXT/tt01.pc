TT 5460 "Go away!" VO__AMICIA__CH08__CHATTER__DISTRACT_07__010__M__1
TT 5461 "Too close..." VO__AMICIA__CH08__CHATTER__DISTRACT_08__010__M__1
TT 5462 "Phew, that was close... But we did it." VO__AMICIA__CH08__CHATTER__DOOR_SAFE__010__M__1
